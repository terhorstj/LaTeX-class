	journal = {Antiviral Chemistry and Chemotherapy},
	number = {2},
	pages = {98-108},
	title = {Characterization of the antiviral activity of highly substituted pyrroles: a novel class of non-nucleoside HIV-1 reverse transcriptase inhibitor},
	url = {https://doi.org/10.1177/095632029500600204},
	volume = {6},
	year = {1995},
	bdsk-url-1 = {https://doi.org/10.1177/095632029500600204}}

