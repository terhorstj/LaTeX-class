@article{briggs,
	abstract = {Abstract Intermolecular potential functions have been developed for use in computer simulations of alkyl ethers. The simple OPLS model was adopted and parameterized to yield good descriptions of bimolecular and ion-molecule complexes as well as to reproduce experimental thermodynamic properties of liquid ethers. The principal testing featured Monte Carlo statistical mechanics simulations for liquid dimethyl ether (DME), ethyl methyl ether (EME), diethyl ether (DEE), and tetrahydrofuran (THF). Average errors of 1--3\% are obtained for the computed densities and heats of vaporization including results for THF at pressures up to 5000 atm. The torsional motion about the central C---O bonds in EME and DEE was included in the simulations using rotational potential functions fit to results of molecular mechanics (MM2) calculations. The liquid-state environment is found to have negligible effect on the conformational equilibria.},
	author = {Briggs, James M. and Matsui, Tooru and Jorgensen, William L.},
	doi = {10.1002/jcc.540110808},
	eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/jcc.540110808},
	journal = {The Journal of Computational Chemistry},
	number = {8},
	pages = {958-971},
	title = {Monte Carlo simulations of liquid alkyl ethers with the OPLS potential functions},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/jcc.540110808},
