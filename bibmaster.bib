@article{crane,
	abstract = {A select series of methyl ether derivatives of vancomcyin aglycon were prepared and examined for antimicrobial activity against vancomycin-sensitive Staphylococcus aureus and vancomycin-resistant Enterococci faecalis as well as their binding affinity for \textsc{d}-Ala-\textsc{d}-Ala and \textsc{d}-Ala-\textsc{d}-Lac. The intent of the study was to elucidate the role selected key methyl groups may play in the improvement of the in vitro antimicrobial profile of the tetra methyl ether derivative of vancomycin aglycon against vancomycin-resistant Enterococci faecalis previously reported. In these studies, methodology for selective derivatization of the A-, B-, and D-ring was developed that defines the relative reactivity of the four phenols of vancomycin aglycon, providing a foundation for future efforts for site-directed modification of the vancomycin aglycon core.},
