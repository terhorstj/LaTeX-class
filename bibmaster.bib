@article{kang,
	abstract = {The effect of basis sets on the structures and energetics of the rotation for the peptide bond of $N$-methylacetamide (NMA) has been investigated at high levels of theory. The structures, dipole moments and thermodynamic properties for \textit{trans}- and \textit{cis}-NMA have been determined at the HF, MP2 and B3LYP levels with 6-31G(d), 6-31G(d,p), 6-31+G(d), 6-31+G(d,p), 6-31++G(d,p), 6-311+G(d,p) and 6-311++G(d,p) basis sets. By comparing the calculated structure and dipole moment of \textit{trans}-NMA and the relative enthalpy ($\Delta H$) of \textit{cis}-NMA in the gas phase with corresponding experimental data, the B3LYP level with 6-31G(d) or 6-31G(d,p) basis sets appears to be the most appropriate among several levels of theory and basis sets considered here. \textit{trans}-NMA is computed to be favored by a total free energy of 2.7kcal/mol than \textit{cis}-NMA in water at the B3LYP/6-31G(d,p) level with the SCI-PCM method, which corresponds to 1.1\% population of \textit{cis}-NMA. This is consistent with the results of NMR experiments in aqueous solution that estimate the \textit{cis} population to be 1.5$\pm$0.1\% and the free energy difference of 2.5$\pm$0.3kcal/mol. In addition, the change in relative solvation free energies is computed to be --0.1kcal/mol at the HF and B3LYP levels with the 6-31G(d,p) basis set as transferred from water to chloroform, which corresponds to the increase of the \textit{cis} population by about 0.3\%, consistent with the value from NMR measurements. Therefore, the SCRF method with proper levels of theory and basis sets seems to be reasonable to describe the solvation of NMA. Our calculated results confirmed that the relative distribution of \textit{trans} and \textit{cis} conformers of NMA is insensitive to the solvent polarity.},
	author = {Young Kee Kang},
	date-added = {2019-06-21 15:01:34 -0700},
	date-modified = {2019-06-21 15:01:42 -0700},
	doi = {https://doi.org/10.1016/S0166-1280(01)00445-6},
	issn = {0166-1280},
	journal = {The Journal of Molecular Structure: THEOCHEM},
	keywords = {-methylacetamide, Ab initio calculations, \textit{cis}--\textit{trans} equilibrium, Solvation},
	number = {1},
	pages = {183-193},
	title = {Ab initio MO and density functional studies on \textit{trans} and \textit{cis} conformers of $N$-methylacetamide},
	url = {http://www.sciencedirect.com/science/article/pii/S0166128001004456},
	volume = {546},
	year = {2001},
	bdsk-url-1 = {http://www.sciencedirect.com/science/article/pii/S0166128001004456},
	bdsk-url-2 = {https://doi.org/10.1016/S0166-1280(01)00445-6}}

@article{vill,
	abstract = {The potential energy surface of $N$-methylacetamide (NMA) is investigated ab initio at the Hartree--Fock/6-31G* level with full geometry optimisation with or without MP2 correlation and thermal corrections in order to characterise its stationary points and the Intrinsic Reaction Coordinate (IRC) of \textit{trans}-\textit{cis} isomerisation. The \textit{cis} and \textit{trans} minima and the two non-equivalent Transition States (TS) of the isomerisation with opposite pyramidalisation of the amidic group are determined. The TS result considerably destablised (∼16 and 21 kcal mol-1) with respect to the most stable equilibrium structure. The lowest energy transition state is the up form (both substituents at N bent toward the carbonyl oxygen), while the down form (with the N lone pair pointing toward the carbonyl oxygen) is higher in energy. A saddle point of index 2 connects the two transition states, ∼8 kcal mol-1 above the TS up, the absence of intermediates being verified. Adding the correlation corrections does not change the energy gaps appreciably. The IRC at HF/6-31G* level has been followed in the most favourable case: correlate deformation of peptide unit and decoupling of methyl groups with respect to the reaction coordinate are shown. Additional TS, depending on methyl groups orientation, confirm the substantial free rotation around the phiv; and $\psi$ torsional angles.},
	author = {Villani, Vincenzo and Alagona, Giuliano and Ghio, Caterina},
	date-added = {2019-06-21 15:00:16 -0700},
	date-modified = {2019-06-21 15:00:32 -0700},
	doi = {10.1023/A:1008393413583},
	issn = {1572-8951},
	journal = {Molecular Engineering},
	number = {2},
	pages = {135--153},
	title = {Ab initio studies on $N$-methylacetamide},
	url = {https://doi.org/10.1023/A:1008393413583},
	volume = {8},
	year = {1998},
	bdsk-url-1 = {https://doi.org/10.1023/A:1008393413583}}

