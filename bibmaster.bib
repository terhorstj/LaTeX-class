	keywords = {Force field, Monte Carlo, Pyridine, Diazenes},
	note = {A Faithful Couple: Qualitative and Quantitative Understanding of Chemistry},
	number = {1},
	pages = {145--155},
	title = {Development of an all-atom force field for heterocycles. Properties of liquid pyridine and diazenes},
	url = {http://www.sciencedirect.com/science/article/pii/S0166128097002376},
	volume = {424},
	year = {1998},
