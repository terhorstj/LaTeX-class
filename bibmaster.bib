	keywords = {, DHFR, Non-active site, Allosteric, Virtual screen, Glide},
	number = {2},
	pages = {418--423},
	title = {Novel non-active site inhibitor of \textit{Cryptosporidium hominis} TS-DHFR identified by a virtual screen},
