@article{jorgmif,
	abstract = {The cytokine MIF is involved in inflammation and cell proliferation via pathways initiated by its binding to the transmembrane receptor CD74. MIF also promotes AMPK activation with potential benefits for response to myocardial infarction and ischemia-reperfusion. Structure-based molecular design has led to the discovery of not only antagonists, but also the first agonists of MIF--CD74 binding. The compounds contain a triazole core that is readily assembled via Cu-catalyzed click chemistry. The agonist and antagonist behaviors were confirmed via study of MIF-dependent ERK1/2 phosphorylation in human fibroblasts.},
	author = {William L. Jorgensen and Sunilkumar Gandavadi and Xin Du and Alissa A. Hare and Alexander Trofimov and Lin Leng and Richard Bucala},
