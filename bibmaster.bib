@article{huis,
	abstract = {Zusammenfassung
Die Carbonestergruppe vermag in 2 Plankonfigurationen aufzutreten. Die Siedepunkte, Dipolmomente und RG-Konstanten der alkalischen Hydrolyse der homologen aliphatischen ω-Lactone (VII, n = 4 bis 16) lehren, dass die Ringstruktur bei VII, n = 4--7 die energiereiche \textit{cis}-Konfiguration erzwingt, w{\"a}hrend VII, n = 10--16 wie offenkettige Ester \textit{trans}-konfiguriert sind. VII, n = 8, 9 nehmen eine {\"U}bergangsstellung ein. Die leichte Lactonhydrolyse sowie die elektrophile Aktivit{\"a}t des ω-Kohlenstoffs sind charakteristisch f{\"u}r das \textit{cis}-Carbonestersystem.
The ester group exists in 2 planar configurations. The boiling points, dipole moments and rate constants of alkaline hydrolysis of the homologous aliphatic ω-lactones (VII, n = 4--16) show that the ring structure forces VII, n = 4--7 into the energetically rich \textit{cis}-configuration; the members n = 10--16 assume the \textit{trans}-configuration of the open-chain esters, while when n = 8, 9 an equilibrium is adopted. The easy lactone hydrolysis as well as the electrophilic activity of the ω-carbon atom are characteristic of the \textit{cis}-ester structure.},
	author = {R. Huisgen and H. Ott},
	date-added = {2019-06-21 15:44:57 -0700},
	date-modified = {2019-06-21 15:45:07 -0700},
	doi = {https://doi.org/10.1016/0040-4020(59)80006-5},
	issn = {0040-4020},
	journal = {Tetrahedron},
	number = {3},
	pages = {253-267},
	title = {Die konfiguration der carbonestergruppe und die sondereigenschaften der lactone},
	url = {http://www.sciencedirect.com/science/article/pii/0040402059800065},
	volume = {6},
	year = {1959},
	bdsk-url-1 = {http://www.sciencedirect.com/science/article/pii/0040402059800065},
	bdsk-url-2 = {https://doi.org/10.1016/0040-4020(59)80006-5}}

