	keywords = {Solvation, Conformational analysis, Thiourea, Isomerization, Free energy of activation},
	note = {Proceedings of the Fifth Annual Conference on Current Trends in Computational Chemistry},
	number = {1},
	pages = {61-68},
	title = {Quantum mechanical and $^{13}$C dynamic NMR study of 1,3-dimethylthiourea conformational isomerizations},
