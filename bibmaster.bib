@article{oplsgasliq,
	abstract = {Abstract Nonbonded and torsional parameters for carboxylate esters, nitriles, and nitro compounds have been developed for the OPLS-AA force field. In addition, torsional parameters for alkanes have been updated. These parameters were fit to reproduce ab initio gas-phase structures and conformational energetics, experimental condensed-phase structural and thermodynamic properties, and experimental free energies of hydration. The computed densities, heats of vaporization, and heat capacities for fifteen liquids are in excellent agreement with experimental values. The new parameters permit accurate molecular modeling of compounds containing a wider variety of functional groups, which are common in organic molecules and drugs. {\copyright} 2001 John Wiley \& Sons, Inc. J Comput Chem 22: 1340--1352, 2001},
	author = {Price, Melissa L. P. and Ostrovsky, Dennis and Jorgensen, William L.},
	date-added = {2019-06-21 19:39:18 -0700},
	date-modified = {2019-06-21 22:42:01 -0700},
	doi = {10.1002/jcc.1092},
	eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/jcc.1092},
	journal = {The Journal of Computational Chemistry},
	keywords = {OPLS force field, esters, nitriles, nitroalkanes, liquid state},
	number = {13},
	pages = {1340-1352},
	title = {Gas-phase and liquid-state properties of esters, nitriles, and nitro compounds with the OPLS-AA force field},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/jcc.1092},
	volume = {22},
	year = {2001},
	bdsk-url-1 = {https://onlinelibrary.wiley.com/doi/abs/10.1002/jcc.1092},
	bdsk-url-2 = {https://doi.org/10.1002/jcc.1092}}

@article{bayes,
	abstract = {Knowledge-based scoring functions are widely used for assessing putative complexes in protein--ligand and protein--protein docking and for structure prediction. Even with large training sets, knowledge-based scoring functions face the inevitable problem of sparse data. Here, we have developed a novel approach for handling the sparse data problem that is based on estimating the inaccuracies in knowledge-based scoring functions. This inaccuracy estimation is used to automatically weight the knowledge-based scoring function with an alternative, force-field-based potential (FFP) that does not rely on training data and can, therefore, provide an improved approximation of the interactions between rare chemical groups. The current version of STScore, a protein--ligand scoring function using our method, achieves a binding mode prediction success rate of 91\% on the set of 100 complexes by Wang et al., and a binding affinity correlation of 0.514 with the experimentally determined affinities in PDBbind. The method presented here may be used with other FFPs and other knowledge-based scoring functions and can also be applied to protein--protein docking and protein structure prediction. {\copyright} 2014 Wiley Periodicals, In.},
	author = {Grinter, Sam Z. and Zou, Xiaoqin},
	date-added = {2019-06-21 19:39:18 -0700},
	date-modified = {2019-06-21 22:42:17 -0700},
	doi = {10.1002/jcc.23579},
	eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/jcc.23579},
	journal = {The Journal of Computational Chemistry},
	keywords = {knowledge-based scoring function, protein, ligand interactions, sparse data, molecular docking},
	number = {12},
	pages = {932-943},
	title = {A Bayesian statistical approach of improving knowledge-based scoring functions for protein--ligand interactions},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/jcc.23579},
